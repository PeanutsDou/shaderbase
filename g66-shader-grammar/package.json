{
  "name": "tree-sitter-g66-shader",
  "version": "0.1.0",
  "description": "G66 shader grammar for tree-sitter (fork of tree-sitter-hlsl with G66-specific extensions)",
  "main": "bindings/node",
  "types": "bindings/node",
  "keywords": [
    "parser",
    "hlsl",
    "shader",
    "g66"
  ],
  "files": [
    "grammar.js",
    "binding.gyp",
    "prebuilds/**",
    "bindings/node/*",
    "queries/*",
    "src/**"
  ],
  "author": "G66 shaderbase project (based on tree-sitter-hlsl by Stephan Seitz)",
  "license": "MIT",
  "dependencies": {},
  "devDependencies": {
    "tree-sitter-c": "git://github.com/tree-sitter/tree-sitter-c.git",
    "tree-sitter-cpp": "git://github.com/tree-sitter/tree-sitter-cpp.git",
    "tree-sitter-cli": "^0.24.7"
  },
  "scripts": {
    "test": "tree-sitter test",
    "test-windows": "tree-sitter test",
    "generate": "tree-sitter generate",
    "parse": "tree-sitter parse"
  },
  "repository": {
    "type": "git",
    "url": "local-only"
  },
  "tree-sitter": [
    {
      "scope": "source.g66_shader",
      "file-types": [
        "nsf",
        "hlsl",
        "fxh"
      ]
    }
  ]
}
